# Telegram Bot
TELEGRAM_BOT_TOKEN=seu_token_do_bot_aqui
TELEGRAM_GROUP_ID=-1001234567890

# Database PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# EFI (Gerencianet) PIX
EFI_CLIENT_ID=seu_client_id_aqui
EFI_CLIENT_SECRET=seu_client_secret_aqui
EFI_CERTIFICATE=./certificado.p12
EFI_SANDBOX=false

# Admin Web Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=senha_segura_aqui
SESSION_SECRET=chave_secreta_sessao_aqui

# Server
PORT=3000
BASE_URL=https://seu-dominio.com

# Webhook EFI
WEBHOOK_SECRET=chave_webhook_efi_aqui
