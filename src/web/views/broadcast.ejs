router.get('/broadcast', requireAuth, (req, res) => {
  res.render('broadcast', { success: null, error: null });
});

router.post('/broadcast', requireAuth, async (req, res) => {
  try {
    const message = (req.body.message || '').trim();

    if (!message) {
      return res.render('broadcast', {
        success: null,
        error: 'Mensagem vazia.',
      });
    }

    const token = process.env.BOT_TOKEN || process.env.TELEGRAM_BOT_TOKEN;
    if (!token) {
      return res.render('broadcast', {
        success: null,
        error: 'BOT_TOKEN não configurado nas variáveis de ambiente.',
      });
    }

    const telegram = new Telegram(token);

    const users = await db.query(`
      SELECT DISTINCT u.telegram_id
      FROM subscriptions s
      JOIN users u ON u.id = s.user_id
      WHERE s.status = 'active'
        AND u.telegram_id IS NOT NULL
    `);

    let sent = 0;
    let failed = 0;

    for (const row of users.rows) {
      const chatId = row.telegram_id;

      try {
        await telegram.sendMessage(chatId, message);
        sent++;
        await new Promise((r) => setTimeout(r, 50));
      } catch (e) {
        failed++;
      }
    }

    return res.render('broadcast', {
      success: `Broadcast enviado: ${sent} sucesso(s), ${failed} falha(s).`,
      error: null,
    });
  } catch (err) {
    return res.render('broadcast', {
      success: null,
      error: 'Erro ao enviar broadcast (verifique logs do servidor).',
    });
  }
});
