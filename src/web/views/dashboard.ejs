<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #1a1a2e; font-family: Arial, sans-serif; color: #a8b2d8; }
    nav { background: #16213e; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #e94560; }
    nav h1 { color: #e94560; font-size: 1.2rem; }
    nav a { color: #a8b2d8; text-decoration: none; margin-left: 1.5rem; font-size: 0.9rem; }
    nav a:hover { color: #e94560; }
    .container { max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .stat-card { background: #16213e; border-radius: 12px; padding: 1.5rem; text-align: center; border: 1px solid #0f3460; }
    .stat-card .number { font-size: 2.5rem; font-weight: bold; color: #e94560; }
    .stat-card .label { color: #a8b2d8; font-size: 0.875rem; margin-top: 0.5rem; }
    h2 { color: #e2e8f0; margin-bottom: 1rem; }
    .quick-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
    .quick-link { background: #16213e; border-radius: 10px; padding: 1.2rem; text-align: center; text-decoration: none; color: #a8b2d8; border: 1px solid #0f3460; transition: border-color 0.2s; }
    .quick-link:hover { border-color: #e94560; color: #e94560; }
    .quick-link .icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  </style>
</head>
<body>
  <nav>
    <h1>🤖 Admin Bot</h1>
    <div>
      <a href="/admin">Dashboard</a>
      <a href="/admin/subscribers">Assinantes</a>
      <a href="/admin/plans">Planos</a>
      <a href="/admin/broadcast">Broadcast</a>
      <a href="/admin/logout">Sair</a>
    </div>
  </nav>
  <div class="container">
    <div class="stats">
      <div class="stat-card">
        <div class="number"><%= activeCount %></div>
        <div class="label">✅ Assinantes Ativos</div>
      </div>
      <div class="stat-card">
        <div class="number"><%= expiringCount %></div>
        <div class="label">⚠️ Vencem em 3 dias</div>
      </div>
      <div class="stat-card">
        <div class="number">R$ <%= Number(totalRevenue).toFixed(2) %></div>
        <div class="label">💰 Receita Total</div>
      </div>
    </div>
    <h2>Acesso Rápido</h2>
    <div class="quick-links">
      <a href="/admin/subscribers" class="quick-link">
        <span class="icon">👥</span>Assinantes
      </a>
      <a href="/admin/plans" class="quick-link">
        <span class="icon">📦</span>Planos
      </a>
      <a href="/admin/broadcast" class="quick-link">
        <span class="icon">📢</span>Broadcast
      </a>
    </div>
  </div>
</body>
</html>
